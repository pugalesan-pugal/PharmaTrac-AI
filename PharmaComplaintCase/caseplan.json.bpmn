        <bpmn:script><![CDATA[const stagesEnteredByKey = ((vars.caseManagerDecisions != null && vars.caseManagerDecisions.stagesEntered != null && vars.caseManagerDecisions.stagesEntered.length > 0)
 
? vars.caseManagerDecisions.stagesEntered.reduce((acc, stage) => {
